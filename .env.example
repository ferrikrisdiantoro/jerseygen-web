# =====================================
# AI Provider — pilih salah satu
# Provider & API key juga bisa diisi lewat tombol Setelan (ikon gerigi) di web.
# Env var di bawah = default untuk SEMUA pengunjung situs.
# =====================================

# Provider aktif: "freepik" | "kieai" | "mock"
# "mock" = tidak memanggil API (untuk test UI tanpa biaya)
AI_PROVIDER=freepik

# -------- Freepik / Magnific (rekomendasi) --------
# Daftar di https://www.freepik.com/api  → ambil API key
FREEPIK_API_KEY=
# Model: "seedream-v4-5-edit" (default, terverifikasi) |
#        "nano-banana-pro" | "nano-banana"
FREEPIK_MODEL=seedream-v4-5-edit
# Base URL API. Default api.freepik.com. Bisa diganti ke
# https://api.magnific.com bila key kamu untuk Magnific.
FREEPIK_BASE_URL=https://api.freepik.com

# -------- KieAI (alternatif) --------
# Daftar di https://kie.ai  → ambil API key
KIEAI_API_KEY=
KIEAI_MODEL=google/nano-banana-edit
