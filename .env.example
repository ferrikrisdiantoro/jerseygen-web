# =====================================
# AI Provider — pilih salah satu
# =====================================

# KieAI (Nano Banana / image edit) — https://kie.ai/
# Daftar akun baru dapat free credit, copy API key ke sini
KIEAI_API_KEY=
KIEAI_MODEL=google/nano-banana-edit

# Freepik AI (alternatif) — https://www.freepik.com/api
FREEPIK_API_KEY=

# Provider aktif: "kieai" atau "freepik" atau "mock"
# "mock" = return gambar contoh tanpa panggil API (untuk dev/testing)
AI_PROVIDER=kieai

# =====================================
# Quota — generate gratis per browser/email
# =====================================
NEXT_PUBLIC_FREE_QUOTA=5
